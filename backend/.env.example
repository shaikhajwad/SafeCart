# App
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Database
DATABASE_URL=postgresql://safecart:safecart_dev@localhost:5432/safecart

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string

# SSLCommerz
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password

# bKash
BKASH_APP_KEY=your_app_key
BKASH_APP_SECRET=your_app_secret
BKASH_USERNAME=your_username
BKASH_PASSWORD=your_password

# Pathao Courier
PATHAO_CLIENT_ID=your_client_id
PATHAO_CLIENT_SECRET=your_client_secret
PATHAO_USERNAME=your_username
PATHAO_PASSWORD=your_password
PATHAO_STORE_ID=your_store_id

# Paperfly Courier
PAPERFLY_API_KEY=your_api_key
PAPERFLY_MERCHANT_ID=your_merchant_id

# Redx Courier
REDX_API_KEY=your_api_key

# eCourier
ECOURIER_API_KEY=your_api_key
ECOURIER_API_PASSWORD=your_password
ECOURIER_MERCHANT_CODE=your_code

# SMS (SSL Wireless)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=SafeCart

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="SafeCart <noreply@safecart.com>"
