{
  "name": "safecart",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:checkout": "npm run dev --workspace=frontend/apps/checkout-web",
    "dev:seller": "npm run dev --workspace=frontend/apps/seller-web",
    "dev:admin": "npm run dev --workspace=frontend/apps/admin-web",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspace=backend",
    "test:integration": "npm run test:integration --workspace=backend",
    "lint": "npm run lint --workspaces --if-present"
  }
}
